# Deployer Wallet Private Key (funded with USDC on Arc Testnet)
# ALWAYS use environment variables, NEVER commit private keys or expose them in source code!
PRIVATE_KEY=your_private_key_hex_here_without_0x_prefix

# Circle Developer-Controlled Wallets API Keys
CIRCLE_API_KEY=your_circle_api_key_here
CIRCLE_ENTITY_SECRET=your_circle_entity_secret_32_byte_hex_here
CIRCLE_DEVELOPER_WALLET_ID=your_circle_developer_wallet_id_uuid_here

# Deployed Contract Addresses (Will be updated once deployed on Arc Testnet)
COURSE_FUND_ADDRESS=0x_deployed_course_fund_address_here
EDU_STREAMER_ADDRESS=0x_deployed_edu_streamer_address_here
SOULBOUND_CERT_ADDRESS=0x_deployed_soulbound_cert_address_here
